---
const screenshots = [
	{ label: 'Login', src: `${import.meta.env.BASE_URL}screenshot/login.png` },
	{ label: 'Ayuda', src: `${import.meta.env.BASE_URL}screenshot/help.png` },
	{ label: 'Inicio', src: `${import.meta.env.BASE_URL}screenshot/home.png` },
	{ label: 'Calificaciones', src: `${import.meta.env.BASE_URL}screenshot/qualifications.png` }
]
---

<section id="screenshots" class="border-y border-white/10 bg-white/2">
	<div class="mx-auto w-full max-w-6xl px-4 py-14 sm:px-6 sm:py-16">
		<div class="max-w-2xl">
			<h2 class="text-2xl font-bold text-white sm:text-3xl">Screenshots de la app</h2>
			<p class="mt-3 text-sm text-slate-300 sm:text-base">Espacios reservados para capturas oficiales de la aplicación.</p>
		</div>

		<div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
			{screenshots.map((item) => (
				<div class="overflow-hidden rounded-2xl border border-white/10 bg-slate-900 p-4 transition duration-300 hover:border-[#EE322F]/45">
					<div
						class="relative mx-auto aspect-390/844 max-h-115 w-full max-w-60 overflow-hidden rounded-2xl border border-white/10 bg-linear-to-b from-[#EE322F]/10 to-slate-900"
					>
						<img src={item.src} alt={`Screenshot ${item.label} de Univalle App`} class="h-full w-full object-cover" loading="lazy" />
						<div class="absolute inset-x-4 bottom-4 rounded-lg bg-black/40 px-3 py-2 text-[11px] text-slate-200">
							{item.label}
						</div>
					</div>
				</div>
			))}
		</div>
	</div>
</section>
