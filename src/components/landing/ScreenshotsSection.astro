---
const screenshots = [
	{ label: 'Pantalla móvil', width: 390, height: 844 },
	{ label: 'Pantalla alta resolución', width: 1284, height: 2778 },
	{ label: 'Pantalla móvil alterna', width: 390, height: 844 }
]
---

<section id="screenshots" class="border-y border-white/10 bg-white/[0.02]">
	<div class="mx-auto w-full max-w-6xl px-4 py-14 sm:px-6 sm:py-16">
		<div class="max-w-2xl">
			<h2 class="text-2xl font-bold text-white sm:text-3xl">Screenshots de la app</h2>
			<p class="mt-3 text-sm text-slate-300 sm:text-base">Espacios reservados para capturas oficiales de la aplicación.</p>
		</div>

		<div class="mt-8 grid gap-4 md:grid-cols-3">
			{screenshots.map((item) => (
				<div class="overflow-hidden rounded-2xl border border-white/10 bg-slate-900 p-4 transition duration-300 hover:border-emerald-300/40">
					<div
						class="relative mx-auto max-h-[380px] w-full max-w-[220px] overflow-hidden rounded-2xl border border-white/10 bg-gradient-to-b from-emerald-400/10 to-slate-900 md:max-h-[460px]"
						style={`aspect-ratio: ${item.width} / ${item.height};`}
					>
						<div class="absolute inset-4 rounded-xl border border-dashed border-white/20"></div>
						<div class="absolute inset-x-4 bottom-4 rounded-lg bg-black/40 px-3 py-2 text-[11px] text-slate-200">
							{item.label} · {item.width}x{item.height}
						</div>
					</div>
				</div>
			))}
		</div>
	</div>
</section>
