---
const features = [
	{
		title: 'Tabulado',
		description: 'Consulta rápida de tu tabulado académico',
		icon: 'M4 7a3 3 0 0 1 3-3h10a3 3 0 0 1 3 3v10a3 3 0 0 1-3 3H7a3 3 0 0 1-3-3V7Zm4 2h8M8 13h5M8 17h3'
	},
	{
		title: 'Historial Académico',
		description: 'Visualiza materias cursadas y resultados',
		icon: 'M8 7V5a2 2 0 1 1 4 0v2m-6 0h10a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V9a2 2 0 0 1 2-2Zm2 5h6m-6 4h4'
	},
	{
		title: 'Evaluación Docente',
		description: 'Acceso a la evaluación de docentes',
		icon: 'M12 17.75 6.2 21l1.1-6.4L2.5 9.9l6.4-.9L12 3l3.1 6 6.4.9-4.8 4.7 1.1 6.4Z'
	},
	{
		title: 'Resolución Académica',
		description: 'Consulta resoluciones académicas',
		icon: 'M7 4h7l5 5v11a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2Zm6 1v5h5M8 14h8M8 18h5'
	},
	{
		title: 'Perfil Estudiantil',
		description: 'Consulta tu información de perfil',
		icon: 'M12 12a4 4 0 1 0 0-8 4 4 0 0 0 0 8Zm-7 9a7 7 0 0 1 14 0'
	},
	{
		title: 'Biblioteca',
		description: 'Estado de cuenta, multas, libros prestados e historial',
		icon: 'M6 4h12a2 2 0 0 1 2 2v12l-4-2-4 2-4-2-4 2V6a2 2 0 0 1 2-2Zm3 4h6m-6 4h6'
	},
	{
		title: 'Carnet Digital',
		description: 'Generado automáticamente desde la información del estudiante',
		icon: 'M4 8a3 3 0 0 1 3-3h10a3 3 0 0 1 3 3v8a3 3 0 0 1-3 3H7a3 3 0 0 1-3-3V8Zm4 0h4m-4 4h8m-8 4h3'
	},
	{
		title: 'Calculadora de Porcentajes',
		description: 'Simula tus notas para saber cómo llevas la materia',
		icon: 'M7 3h10a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2Zm1 5h8m-8 4h8m-8 4h4'
	}
]
---

<section id="features" class="mx-auto w-full max-w-6xl px-4 py-14 sm:px-6 sm:py-16">
	<div class="max-w-2xl">
		<h2 class="text-2xl font-bold text-white sm:text-3xl">Funciones principales</h2>
		<p class="mt-3 text-sm text-slate-300 sm:text-base">Todo lo que necesitas para gestionar tu vida académica desde el móvil.</p>
	</div>

	<div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
		{features.map((feature) => (
			<article class="group rounded-2xl border border-white/10 bg-white/3 p-5 transition duration-300 hover:-translate-y-1 hover:border-emerald-300/40 hover:bg-white/5">
				<div class="inline-flex h-11 w-11 items-center justify-center rounded-xl border border-emerald-300/30 bg-emerald-300/10 text-emerald-200">
					<svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
						<path d={feature.icon}></path>
					</svg>
				</div>
				<h3 class="mt-4 text-base font-semibold text-white">{feature.title}</h3>
				<p class="mt-2 text-sm leading-relaxed text-slate-300">{feature.description}</p>
			</article>
		))}
	</div>
</section>
