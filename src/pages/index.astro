---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import HeroSection from '../components/landing/HeroSection.astro';
import AboutSection from '../components/landing/AboutSection.astro';
import FeaturesSection from '../components/landing/FeaturesSection.astro';
import ScreenshotsSection from '../components/landing/ScreenshotsSection.astro';
import OpenSourceSection from '../components/landing/OpenSourceSection.astro';
---

<Layout
	title="Univalle App | Tu información académica en un solo lugar"
	description="Landing oficial de Univalle App: aplicación no oficial de la Universidad del Valle para consultar información académica de forma moderna y simple."
	path="/"
>
	<Header />
	<main>
		<HeroSection />
		<AboutSection />
		<FeaturesSection />
		<ScreenshotsSection />
		<OpenSourceSection />
	</main>
	<Footer />
</Layout>
